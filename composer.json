{
    "name": "phoenix84pl/pphpa",
    "description": "Phoenix PHP Application - szablon aplikacji bazujacy na PPHPC",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.0",
        "phoenix84pl/pphpc": "dev-main",
        "nyholm/psr7-server": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "Phoenix\\App\\": "src/"
        }
    },
    "repositories": {
        "pphpc": {
            "type": "vcs",
            "url": "https://github.com/phoenix84pl/pphpc"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php -r \"@mkdir('public', 0755, true); copy('vendor/phoenix84pl/pphpc/templates/.htaccess', 'public/.htaccess');\""
        ],
        "post-update-cmd": [
            "php -r \"@mkdir('public', 0755, true); copy('vendor/phoenix84pl/pphpc/templates/.htaccess', 'public/.htaccess');\""
        ]
    }
}
